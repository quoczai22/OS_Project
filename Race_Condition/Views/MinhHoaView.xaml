<UserControl x:Class="Race_Condition.Views.MinhHoaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Race_Condition.Views"
             xmlns:vm="clr-namespace:Race_Condition.ViewModels"
             mc:Ignorable="d" 
             Background="White"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <vm:MinhHoaViewModel/>
    </UserControl.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Mô tả" FontWeight="Bold">
            <TextBlock Margin="10"
                       TextWrapping="Wrap"
                       Text="Chế độ này minh họa race condition với 2 luồng A và B trên biến dùng chung count = 10. Mỗi luồng tăng 1 lần để log rõ các bước đọc - xử lý - ghi."/>
        </GroupBox>

        <UniformGrid Grid.Row="1" Columns="2" Margin="0,10,0,10" Height="40">
            <Button Content="Minh họa không có lock"
                    Margin="0,0,5,0"
                    Background="#f44336"
                    Foreground="White"
                    Command="{Binding DemoWithoutLockCommand}"/>
            <Button Content="Minh họa có lock"
                    Margin="5,0,0,0"
                    Background="#4caf50"
                    Foreground="White"
                    Command="{Binding DemoWithLockCommand}"/>
        </UniformGrid>

        <GroupBox Grid.Row="2" Header="Nhật ký minh họa" FontWeight="Bold">
            <ListBox Margin="5" ItemsSource="{Binding Logs}" Background="#f8f9fa"/>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="Kết quả" FontWeight="Bold" Margin="0,10,0,0">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Giá trị kỳ vọng:" Margin="0,5,10,5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GiaTriKyVong}" FontWeight="Bold"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Giá trị thực tế:" Margin="0,5,10,5"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GiaTriThuc}" FontWeight="Bold"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Kết luận:" Margin="0,5,10,5"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Status}" FontWeight="Bold" Foreground="DarkBlue" TextWrapping="Wrap"/>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
